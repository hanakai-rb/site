<ol role="list" data-testid="<%= testid %>" data-depth="<%= depth %>">
  <% headings.each do |(heading, child_headings)| %>
    <li>
      <% depths = ["pl-4", "pl-7", "pl-10", "pl-13"] %>

      <a
        class="
          inline-block py-[4px] pr-2 <%= depths[depth] %> border-l-2 border-neutral-200 dark:border-neutral-700 text-neutral
          hover:text-neutral-800 dark:hover:text-neutral-200 hover:border-neutral-400 dark:hover:border-neutral-500
          transition-color duration-200 text-md lg:text-sm leading-tighter
        "
        data-depth="<%= depth %>"
        href="<%= heading.href %>"
      >
        <%= heading.text %>
      </a>

      <% if child_headings.any? %>
        <%= render "doc_pages/toc_headings", headings: child_headings, testid: nil, depth: depth + 1 %>
      <% end %>
    </li>
  <% end %>
</ol>
