<div
  data-defo-theme-switcher
  role="radiogroup"
  aria-label="Theme"
  class="
    relative inline-flex items-center h-10 md:h-7 rounded-full p-0.5
    bg-(--hk-color-neutral-subtle) inset-shadow-sm
  "
>
  <span
    data-theme-switcher-indicator
    aria-hidden="true"
    class="
      absolute top-0.5 left-0.5 size-9 md:size-6 rounded-full
      [[data-theme-pref=light]_&]:translate-x-0
      [[data-theme-pref=system]_&]:translate-x-9 md:[[data-theme-pref=system]_&]:translate-x-6
      [[data-theme-pref=dark]_&]:translate-x-[4.5rem] md:[[data-theme-pref=dark]_&]:translate-x-12
      [[data-theme-pref=system]_&]:rounded-lg md:[[data-theme-pref=system]_&]:rounded-md
      bg-white dark:bg-neutral-700
      transition-[translate,border-radius] duration-200 ease-in-out
    "
  ></span>

  <% [
    ["light", "sun", "Light"],
    ["system", "system", "Match system"],
    ["dark", "moon", "Dark"],
  ].each do |value, icon, label| %>
    <button
      type="button"
      role="radio"
      data-theme-switcher-option="<%= value %>"
      aria-checked="false"
      aria-label="<%= label %>"
      tabindex="-1"
      class="
        relative z-10 size-9 md:size-6 flex items-center justify-center cursor-pointer
        text-neutral-500 dark:text-neutral-400
        aria-checked:text-neutral-800 dark:aria-checked:text-white
        transition-colors
      "
    >
      <%= render "svgs/icons/#{icon}", height: 16, width: 16, class_name: "fill-current size-4 md:size-3.5" %>
    </button>
  <% end %>
</div>
