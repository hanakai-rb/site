<div class="md:hidden bg-neutral" id="nav-mobile">
  <div class="overflow-hidden flex justify-center min-h-0 md:hidden">
    <nav class="max-w-sm flex-1 pt-4 pb-6 px-2 text-center">
      <div class="mb-4">
        <p class="px-3 py-2 text-lg font-bold">Projects</p>

        <div class="flex gap-2 justify-center">
          <% nav_projects.each do |project| %>
            <%= render "layouts/header/nav_project_card_mobile", project: project %>
          <% end %>
        </div>
      </div>

      <ul class="flex flex-col items-center mb-4">
        <% nav_items.each do |item| %>
          <%= render "layouts/header/nav_item_mobile", label: item.label, url: item.url %>
        <% end %>
      </ul>

      <%= render "layouts/header/theme_switcher" %>
    </nav>
  </div>
</div>
