<header
  class="
    sticky top-0 z-30
    pl-[calc(env(safe-area-inset-left)-var(--spacing)*4)] pr-[calc(env(safe-area-inset-right)-var(--spacing)*4)]
  "
  data-defo-size-to-var="<%= { blockVarName: "--hk-nav-height" }.to_json %>"
>
  <%= render "layouts/header/dismissible_banner" %>

  <div
    class="
      bg-neutral text-neutral flex items-center gap-2 lg:gap-4 px-4 lg:px-6
      pt-2 pb-1 justify-between
    "
  >
    <div
      class="
        relative
        after:hidden after:md:block after:w-0.5 after:rounded-xs after:bg-(--hk-color-bg-primary-reversed) after:opacity-20
        after:top-0 after:bottom-0 after:absolute after:right-0
        md:pr-5 lg:pr-8
      "
    >
      <a
        class="
          hk-brand flex gap-3 font-extrabold text-xl antialiased tracking-tight
          lg:text-2xl items-center
        "
        href="/"
      >
        <%= render "svgs/hanakai_logo_animated", height: 32, width: 32, trigger_selector: ".hk-brand" %>
        <%= render "shared/names/hanakai" %>
      </a>
    </div>

    <%= render "header/nav_desktop", nav_items: nav_items %>

    <%= render "header/nav_mobile_buttons" %>
  </div>

  <%= render "header/nav_mobile", nav_items: nav_items %>

  <div class="relative h-[7px]">
    <div class="absolute inset-x-0 top-0 h-[14px]">
      <%= render "svgs/wiggle", class_name: "", height: 14, stroke_width: 0, fill_top: "fill-(--hk-color-bg-neutral)" %>
    </div>

    <div class="absolute inset-x-0 top-0 h-[14px] [clip-path:inset(0_1rem)]">
      <%= render "svgs/wiggle", class_name: "text-[var(--hk-color-b-primary)]", height: 14, stroke_width: 2 %>
    </div>
  </div>
</header>
