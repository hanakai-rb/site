<a
  href="<%= href %>"
  class="
    inline-flex items-center gap-3
    border-3 b-primary bg-primary text-primary-reversed
    rounded-xl px-4 py-2
    font-bold text-lg
    hover:opacity-90 transition-opacity
    <%= class_name if defined?(class_name) %>
  "
>
  <% if slot? :prefix %>
    <%= render_slot :prefix %>
  <% end %>

  <%= label %>

  <% if slot? :suffix %>
    <%= render_slot :suffix %>
  <% end %>
</a>
