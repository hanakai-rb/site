<%# Community %>
<section class="py-16 lg:py-20 -mx-4 lg:-mx-6 px-4 lg:px-6">
  <div class="max-w-6xl mx-auto">
    <header class="text-center mb-12">
      <h2 class="text-4xl lg:text-5xl font-black tracking-tighter mb-5">
        Built on community
      </h2>

      <p class="text-2xl lg:text-3xl tracking-tight text-balance">
        For people who bring kindness, curiosity, and care
      </p>
    </header>

    <div class="flex flex-col lg:flex-row gap-5 lg:gap-16 items-center">
      <div class="lg:w-7/12 flex justify-center lg:justify-end lg:order-2">
        <div class="relative w-full">
          <%# Photo 1: hanakai tint, top-left %>
          <div class="relative z-0 w-[65%] rounded-xl overflow-hidden shadow-lg">
            <div class="relative">
              <div
                class="absolute inset-0 rounded-xl z-0"
                style="background: oklch(from var(--color-hanami-400) calc(l + 0.09) calc(c + 0.1) h)"
              ></div>

              <img
                src="<%= asset_url("community-1.png") %>"
                alt="Hanakai community members"
                loading="lazy"
                decoding="async"
                class="
                  community-slide block w-full rounded-xl grayscale relative z-10
                  mix-blend-luminosity contrast-120
                "
              >

              <img
                src="<%= asset_url("community-3.png") %>"
                alt="Hanakai community members"
                loading="lazy"
                decoding="async"
                class="
                  community-slide absolute inset-0 w-full h-full rounded-xl
                  object-cover grayscale z-10 mix-blend-luminosity
                  contrast-120
                "
              >

              <img
                src="<%= asset_url("community-5.png") %>"
                alt="Hanakai community members"
                loading="lazy"
                decoding="async"
                class="
                  community-slide absolute inset-0 w-full h-full rounded-xl
                  object-cover grayscale z-10 mix-blend-luminosity
                  contrast-120
                "
              >
            </div>
          </div>

          <%# Photo 2: rom tint, bottom-right, overlapping %>
          <div
            class="
              relative z-10 w-[65%] ml-auto -mt-12 rounded-xl
              overflow-hidden shadow-lg
            "
          >
            <div class="relative">
              <div
                class="absolute inset-0 rounded-xl z-0"
                style="background: oklch(from var(--color-rom-400) calc(l + 0.2) calc(c + 0.2) h)"
              ></div>

              <img
                src="<%= asset_url("community-2.png") %>"
                alt="Hanakai community members"
                loading="lazy"
                decoding="async"
                class="
                  community-slide block w-full rounded-xl grayscale relative z-10
                  mix-blend-luminosity contrast-120
                "
              >

              <img
                src="<%= asset_url("community-4.png") %>"
                alt="Hanakai community members"
                loading="lazy"
                decoding="async"
                class="
                  community-slide absolute inset-0 w-full h-full rounded-xl
                  object-cover grayscale z-10 mix-blend-luminosity
                  contrast-120
                "
              >

              <img
                src="<%= asset_url("community-6.png") %>"
                alt="Hanakai community members"
                loading="lazy"
                decoding="async"
                class="
                  community-slide absolute inset-0 w-full h-full rounded-xl
                  object-cover grayscale z-10 mix-blend-luminosity
                  contrast-120
                "
              >
            </div>
          </div>
        </div>
      </div>

      <div class="lg:w-5/12 pb-8 lg:ml-7">
        <p class="text-xl lg:text-2xl mb-3">
          The Hanakai community is a place where people of all backgrounds and
          experience levels can feel respected, and can share and grow. A place
          for people to be proud of, and feel safe within.
        </p>

        <p class="text-xl lg:text-2xl mb-12">
          <strong>We do not tolerate</strong> nazis, transphobes, racists, or
          any kind of bigotry.
          <a href="/conduct" class="
            text-[var(--hk-color-text-link)]
            underline
            decoration-[var(--hk-color-text-link-underline)]
            decoration-[3px]
            [text-decoration-skip-ink:none]
            hover:text-[var(--hk-color-text-link-active)]
          "> See our Code of Conduct for more. </a>
        </p>

        <div class="flex flex-wrap gap-3">
          <%= render_with_slots "shared/components/button_primary", href: "https://discourse.hanamirb.org", label: "Discussion forum" do |btn| %>
            <% btn.slot :suffix do %>
              <%= render "svgs/icons/chat_text", width: 24, height: 24, class_name: "text-current" %>
            <% end %>
          <% end %>

          <%= render_with_slots "shared/components/button_primary", href: "https://discord.com/invite/KFCxDmk3JQ", label: "Discord" do |btn| %>
            <% btn.slot :suffix do %>
              <%= render "svgs/icons/discord_logo", width: 24, height: 24, class_name: "fill-current" %>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</section>
