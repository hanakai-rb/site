<%# Sponsors %>
<section>
  <div class="max-w-6xl mx-auto z-10 relative">
    <header class="text-center mb-12">
      <h2 class="text-4xl lg:text-5xl font-black tracking-tight mb-3">
        Supported by
      </h2>

      <p class="text-xl lg:text-3xl tracking-tight text-balance">
        Hanakai is made possible by our wonderful sponsors
      </p>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-[2fr_1fr_2fr] gap-6 mb-12">
      <%# Sidekiq %>
      <a
        href="https://sidekiq.org"
        class="flex items-center justify-center p-10 bg-white rounded-2xl border-3 border-rose-900 hover:opacity-90 transition-opacity min-h-64 shadow-lg"
      >
        <%= image_tag "sponsors/sidekiq-square.svg", alt: "Sidekiq", class: "max-w-full w-48" %>
      </a>

      <%# Community sponsor %>
      <a
        href="https://github.com/baweaver"
        class="flex items-center justify-center p-6 bg-white rounded-2xl border-3 border-[#B1003E] hover:opacity-90 transition-opacity shadow-lg"
      >
        <%= image_tag "sponsors/lemur.png", alt: "Brandon Weaver", class: "max-w-full w-32" %>
      </a>

      <%# Secondary sponsors %>
      <div class="flex flex-col gap-6">
        <a
          href="https://www.honeybadger.io"
          class="flex-1 flex items-center justify-center px-6 py-4 bg-white rounded-2xl border-3 border-orange-500 hover:opacity-90 transition-opacity shadow-lg"
        >
          <%= image_tag "sponsors/honeybadger.png", alt: "Honeybadger", class: "max-h-14 w-auto" %>
        </a>

        <a
          href="https://www.fastruby.io"
          class="flex-1 flex items-center justify-center px-6 py-4 bg-white rounded-2xl border-3 border-red-500 hover:opacity-90 transition-opacity shadow-lg"
        >
          <%= image_tag "sponsors/fastruby.png", alt: "FastRuby.io", class: "max-h-16 w-auto" %>
        </a>

        <a
          href="https://www.appsignal.com"
          class="flex-1 flex items-center justify-center px-6 py-4 bg-white rounded-2xl border-3 border-[#1B44DA] hover:opacity-90 transition-opacity shadow-lg"
        >
          <%= image_tag "sponsors/appsignal.png", alt: "AppSignal", class: "max-h-12 w-auto" %>
        </a>
      </div>
    </div>

    <div class="text-center max-w-2xl mx-auto">
      <p class="text-2xl mb-3 text-balance">
        We’re also supported by our many community patrons.
      </p>
      <p class="text-2xl mb-8 text-balance">
        Become a Hanakai sponsor or patron today, and help us build a diverse future for Ruby.
      </p>

      <%= render_with_slots "shared/components/button_primary", href: "/sponsor", label: "Support the Hanakai project" do |btn| %>
        <% btn.slot :suffix do %>
          <%= render "svgs/icons/hand_heart", width: 24, height: 24, class_name: "fill-current" %>
        <% end %>
      <% end %>
    </div>
  </div>

  <div class="-mx-4 z-0 -mt-30">
  <%= render "svgs/footer_illustration" %>
  </div>
</section>
