<%# Sponsors %>
<section class="py-16 lg:py-20 -mx-4 lg:-mx-6 px-4 lg:px-6 bg-stone-50 rounded-2xl">
  <div class="max-w-5xl mx-auto">
    <header class="text-center mb-12">
      <h2 class="text-4xl lg:text-5xl font-black tracking-tight mb-3">Supported by</h2>
      <p class="text-xl lg:text-2xl tracking-tight">
        Hanakai is made possible by our wonderful sponsors
      </p>
    </header>

    <div class="flex flex-wrap justify-center items-center gap-8 lg:gap-12 mb-12">
      <a href="https://sidekiq.org" class="opacity-80 hover:opacity-100 transition-opacity">
        <%= render "svgs/sponsors/sidekiq_logo_horizontal", height: 50, width: 170 %>
      </a>
    </div>

    <div class="text-center max-w-2xl mx-auto">
      <p class="text-lg leading-relaxed mb-6">
        We’re also supported by our many community patrons. Become a Hanakai sponsor or patron
        today, and help us build a diverse future for Ruby.
      </p>
      <%= render_with_slots "shared/components/button_primary", href: "/sponsor", label: "Support the Hanakai project" do |btn| %>
        <% btn.slot :suffix do %>
          <%= render "svgs/icons/arrow_right", width: 20, height: 18, class_name: "fill-current" %>
        <% end %>
      <% end %>
    </div>
  </div>
</section>
