            "
          ></div>
        </div>

        <div class="pl-10 text-xl">
          <p class="font-bold text-primary">Joshua Wood</p>

          <p class="opacity-60">
            <a href="https://www.honeybadger.io" class="hover:underline">
              Honeybadger
            </a>
          </p>
        </div>
      </blockquote>
    </div>

    <%# Right column – offset down to stagger %>
    <div class="flex-1 flex flex-col lg:pt-16">
      <blockquote class="theme-rom mb-10">
        <div
          class="
            relative bg-neutral border-3 b-primary rounded-2xl p-8 pt-7
            shadow-lg mb-4
          "
        >
          <p class="text-xl">
            “At FastRuby we believe in the value of diverse and inclusive
            communities. With our yearly contribution to Hanami we are investing
            in a framework that brings positive change to our beloved Ruby
            ecosystem. We envision a future where projects like Hanami, Roda,
            Sinatra, Cuba, and Padrino push the boundaries of what’s possible in
            Ruby.”
          </p>

          <div
            class="
              absolute bottom-0 translate-y-1/2 left-12 w-5 h-5 rotate-45
              bg-neutral border-b-3 border-r-3 b-primary rounded-br-md
            "
          ></div>
        </div>

        <div class="pl-10 text-xl">
          <p class="font-bold text-primary">Ernesto Tagwerker</p>

          <p class="opacity-60">
            <a href="https://www.fastruby.io" class="hover:underline">
              FastRuby
            </a>
          </p>
        </div>
      </blockquote>

      <blockquote class="theme-rom">
        <div
          class="
            relative bg-neutral border-3 b-primary rounded-2xl p-8 pt-7
            shadow-lg mb-4
          "
        >
          <p class="text-xl">
            “At AppSignal, we believe in sustainable open-source software and
            are happy to contribute to Hanami’s development by enabling others
