</section>

<%# Individual sponsors %>
<section class="py-12 lg:py-16 max-w-6xl mx-auto w-full">
  <header class="text-center mb-10 max-w-3xl mx-auto">
    <h2 class="text-4xl lg:text-5xl font-black tracking-tighter mb-5">
      Become an individual sponsor
    </h2>

    <p class="text-2xl text-balance">
      There are several ways to support Hanakai as a community member.
    </p>
  </header>

  <div
    class="
      grid grid-cols-1 lg:grid-cols-3 divide-y lg:divide-y-0 lg:divide-x
      divide-(--hk-color-neutral-subtle) mb-10
    "
  >
    <div
      class="
        py-8 lg:pt-0 lg:pb-4 lg:px-10 first:pt-0 first:lg:pl-0 last:pb-0
        last:lg:pr-0 text-center
      "
    >
      <%= render "svgs/icons/hand_heart", width: 32, height: 32, class_name: "mb-4 mx-auto" %>

      <h3 class="text-xl font-bold mb-2">Sponsor directly</h3>

      <p class="text-lg">
        Support Hanakai through
        <a href="https://opencollective.com/hanami" class="
          underline decoration-(--hk-color-text-link-underline)
          decoration-[3px] [text-decoration-skip-ink:none]
          hover:text-(--hk-color-text-link-active)
        ">Open Collective</a>
        or
        <a href="https://github.com/sponsors/hanami" class="
          underline decoration-(--hk-color-text-link-underline)
          decoration-[3px] [text-decoration-skip-ink:none]
          hover:text-(--hk-color-text-link-active)
        ">GitHub Sponsors</a>
        at whatever amount you choose.
      </p>
    </div>

    <div
      class="
        py-8 lg:pt-0 lg:pb-4 lg:px-10 first:pt-0 first:lg:pl-0 last:pb-0
        last:lg:pr-0 text-center
      "
    >
      <%= render "svgs/icons/notepad", width: 32, height: 32, class_name: "mb-4 mx-auto" %>

      <h3 class="text-xl font-bold mb-2">Bring it to work</h3>

      <p class="text-lg">
        Share this pitch with the financial decision-makers at your workplace.
        Every business sponsor matters.
      </p>
    </div>

    <div
      class="
        py-8 lg:pt-0 lg:pb-4 lg:px-10 first:pt-0 first:lg:pl-0 last:pb-0
        last:lg:pr-0 text-center
      "
    >
      <%= render "svgs/icons/chat_text", width: 32, height: 32, class_name: "mb-4 mx-auto" %>

      <h3 class="text-xl font-bold mb-2">Spread the word</h3>

      <p class="text-lg">
        Share our work on social media. Big things are happening for Hanakai and
        we want everyone to know.
      </p>
    </div>
  </div>

  <%# Individual sponsor count + avatars %>
  <div class="text-center mb-10 py-8">
    <p class="text-2xl text-balance mb-6 tracking-tight">
      Thank you to our 19 individual sponsors
    </p>

    <div class="flex flex-wrap justify-center gap-1">
      <% individual_sponsors.each do |sponsor| %>
        <% if sponsor[:private] %>
          <span
            class="
              w-12 h-12 rounded-full ring-2 ring-white dark:ring-neutral-900
              bg-neutral-100 dark:bg-neutral-800 flex items-center
              justify-center
            "
            title="Private sponsor"
          >
            <svg
              aria-label="Private Sponsor"
              role="img"
              height="20"
              viewBox="0 0 16 16"
              width="20"
              class="text-neutral-400 fill-current"
            >
              <path
                d="M10.561 8.073a6.005 6.005 0 0 1 3.432 5.142.75.75 0 1 1-1.498.07 4.5 4.5 0 0 0-8.99 0 .75.75 0 0 1-1.498-.07 6.004 6.004 0 0 1 3.431-5.142 3.999 3.999 0 1 1 5.123 0ZM10.5 5a2.5 2.5 0 1 0-5 0 2.5 2.5 0 0 0 5 0Z"
              ></path>
            </svg>
          </span>
        <% else %>
          <a
            href="https://github.com/<%= sponsor[:login] %>"
            title="@<%= sponsor[:login] %>"
          >
            <img
              src="https://avatars.githubusercontent.com/u/<%= sponsor[:avatar_id] %>?s=96&v=4"
              alt="@<%= sponsor[:login] %>"
              width="48"
              height="48"
              class="
                w-12 h-12 rounded-full ring-2 ring-white
                dark:ring-neutral-900
              "
            >
          </a>
        <% end %>
      <% end %>
    </div>
  </div>

  <div class="flex flex-wrap justify-center gap-3">
    <%= render_with_slots "shared/components/button_primary",
          href: "https://opencollective.com/hanami",
          label: "Sponsor on Open Collective" do |btn| %>
      <% btn.slot :suffix do %>
        <%= render "svgs/icons/hand_heart", width: 24, height: 24, class_name: "text-current" %>
      <% end %>
    <% end %>

    <%= render_with_slots "shared/components/button_primary",
          href: "https://github.com/sponsors/hanami",
          label: "Sponsor on GitHub" do |btn| %>
      <% btn.slot :suffix do %>
        <%= render "svgs/icons/hand_heart", width: 24, height: 24, class_name: "text-current" %>
      <% end %>
    <% end %>
  </div>
</section>

<%# Closing %>
<section class="max-w-3xl mx-auto w-full py-12 lg:py-16">
  <div
    class="
      relative bg-hanakai-50 dark:bg-hanakai-950 border border-hanakai-200
      rounded-lg dark:border-neutral-800 shadow-xl p-8 lg:p-12
    "
    style="transform: rotate(1deg)"
  >
    <div class="space-y-5 max-w-2xl">
      <p class="text-xl">
        <strong class="font-bold">Thank you for your support</strong> – it
        means the world to us!
      </p>

      <p class="text-xl">
        If you have any questions, I’d love to hear from you. Please feel free
        to
        <a href="mailto:sponsor@hanakai.org" class="
          underline decoration-(--hk-color-text-link-underline)
          decoration-[3px] [text-decoration-skip-ink:none]
          hover:text-(--hk-color-text-link-active)
        ">contact me directly</a>.
      </p>

      <div class="flex items-center gap-3 pt-2">
        <img
          src="https://avatars.githubusercontent.com/timriley?size=130"
          alt="Tim Riley"
          class="w-16 h-16 rounded-full shrink-0"
          width="64"
          height="64"
        >

        <div class="text-xl">
          <p class="font-black tracking-tight">Tim Riley</p>
          <p>Hanakai project lead</p>
        </div>
      </div>
    </div>
  </div>
</section>
