<% content_for :title, "Become a Hanakai sponsor" %>

<%= content_for :pre_main do %>
  <div class="h-0 overflow-visible pt-4 lg:pt-8 pointer-events-none relative z-0">
    <%= render "svgs/hero_illustration", show_logos: false %>
  </div>
<% end %>

<%# Hero %>
<section class="py-12 lg:py-16 text-center max-w-3xl mx-auto">
  <div class="flex justify-center mb-6">
    <%= render "svgs/hanakai_logo", width: 134, height: 134 %>
  </div>

  <h1
    class="
      text-5xl lg:text-7xl font-black tracking-tighter leading-none mb-6
      text-balance
    "
  >
    Sponsor Hanakai
  </h1>

  <p class="text-2xl text-balance mb-8">
    Help us build a diverse future for Ruby.
  </p>

  <div class="flex flex-wrap justify-center gap-3">
    <%= render_with_slots "shared/components/button_primary",
          href: "https://opencollective.com/hanami",
          label: "Sponsor on Open Collective" do |btn| %>
      <% btn.slot :suffix do %>
        <%= render "svgs/icons/hand_heart", width: 24, height: 24, class_name: "text-current" %>
      <% end %>
    <% end %>

    <%= render_with_slots "shared/components/button_primary",
          href: "https://github.com/sponsors/hanami",
          label: "Sponsor on GitHub" do |btn| %>
      <% btn.slot :suffix do %>
        <%= render "svgs/icons/hand_heart", width: 24, height: 24, class_name: "text-current" %>
      <% end %>
    <% end %>
  </div>
</section>

<%# Tim's letter %>
<section class="max-w-5xl mx-auto w-full pb-8 lg:pb-12">
  <div
    class="
      relative bg-hanakai-50 dark:bg-hanakai-950 border border-hanakai-200
      rounded-lg dark:border-neutral-800 shadow-xl p-8 lg:p-12
      lg:bg-[linear-gradient(to_right,transparent,var(--color-hanakai-100)_50%,transparent_50%)]
      dark:lg:bg-[linear-gradient(to_right,transparent,rgba(0,0,0,0.4)_50%,transparent_50%)]
    "
    style="transform: rotate(-1deg)"
  >
    <%# Balanced columns %>
    <div class="columns-1 lg:columns-2 gap-24 space-y-5">
      <p class="text-lg">
        For more than a decade, Hanami, Dry and Rom have offered Ruby developers
        something different: tools built around clarity, flexibility, and a
        genuine belief that there’s more than one good way to build an app.
      </p>

      <p class="text-lg">
        This year we’ve brought all three together under Hanakai, a unified
        project with a shared community and future.
      </p>

      <p class="text-lg font-semibold">
        Now comes the part where we make it last.
      </p>

      <p class="text-lg">
        Sustaining Hanakai means steady, ongoing work: releasing gems, improving
        your developer experience, and growing our community. This needs me to
        show up consistently, over the long run. And beyond that, we want more
        of our maintainers to get the recognition and compensation they deserve.
      </p>

      <p class="text-lg mb-7">
        Ruby is a better place when there are real alternatives to reach for. If
        you believe this – or if Dry, Rom or Hanami are already doing important
        work somewhere in your stack — sponsorship is how you grow Hanakai and
        Ruby’s diversity along with it.
      </p>

      <%# Signature %>
      <div class="flex items-center gap-3 break-inside-avoid">
        <img
          src="https://avatars.githubusercontent.com/timriley?size=130"
          alt="Tim Riley"
          class="w-16 h-16 rounded-full shrink-0"
          width="64"
          height="64"
        >

        <div class="text-xl">
          <p class="font-black tracking-tight">Tim Riley</p>
          <p>Hanakai project lead</p>
        </div>
      </div>
    </div>
  </div>
</section>

<%# Milestone tracker %>
<section class="py-12 lg:py-16 max-w-4xl mx-auto w-full">
  <header class="text-center mb-12">
    <h2 class="text-4xl lg:text-5xl font-black tracking-tighter mb-3">
      How we use your money
    </h2>

    <p class="text-2xl">Every dollar goes directly to sustaining Hanakai.</p>
  </header>

  <%# Desktop tracker %>
  <div class="hidden lg:block relative mb-12">
    <%# Marker bubble – sits above the track %>
    <div class="relative mb-3 mx-8">
      <div
        class="absolute"
        style="left: 29%; transform: translate(-50%, -24px)"
      >
        <div
          class="
            bg-hanakai-300 text-lg font-bold px-3 py-2 rounded-lg
            whitespace-nowrap text-center dark:text-neutral-900
          "
        >
          Currently $26k/year
        </div>

        <div class="flex justify-center">
          <div
            class="
              w-0 h-0 border-l-6 border-r-6 border-t-6 border-l-transparent
              border-r-transparent border-hanakai-300
            "
          ></div>
        </div>
      </div>

      <div class="h-8"></div>
    </div>

    <%# Track %>
    <div class="relative h-3 bg-neutral-200 dark:bg-neutral-700 rounded-full mx-8 mb-6">
      <%# Filled: $26k is 26/30 ≈ 87% of the first third ≈ 29% of total track %>
      <div
        class="absolute left-0 top-0 h-full bg-hanakai-300 rounded-full"
        style="width: 29%"
      ></div>

      <%# Dot at current position %>
      <div
        class="
          absolute top-1/2 -translate-y-1/2 -translate-x-1/2 w-5 h-5
          bg-hanakai-300 border-4 border-white dark:border-neutral-900
          rounded-full shadow-md
        "
        style="left: 29%"
      ></div>

      <%# Segment dividers %>
      <div
        class="
          absolute top-1/2 -translate-y-1/2 w-0.5 h-5 bg-neutral-300
          dark:bg-neutral-600
        "
        style="left: 33.33%"
      ></div>

      <div
        class="
          absolute top-1/2 -translate-y-1/2 w-0.5 h-5 bg-neutral-300
          dark:bg-neutral-600
        "
        style="left: 66.66%"
      ></div>
    </div>

    <%# Labels %>
    <div class="grid grid-cols-3 mt-5 mx-8 gap-4">
      <div class="text-center">
        <p class="font-bold text-xl">Up to $30k/year</p>

        <p class="mt-1">
          Funds one day a week of Tim's time as lead maintainer
        </p>
      </div>

      <div class="text-center">
        <p class="font-bold text-xl">$30–40k/year</p>

        <p class="mt-1">
          Builds a reserve for community and promotional activities
        </p>
      </div>

      <div class="text-center">
        <p class="font-bold text-xl">Beyond $40k/year</p>

        <p class="mt-1">
          Pays additional Hanakai maintainers for their ongoing work
        </p>
      </div>
    </div>
  </div>

  <%# Mobile stack %>
  <div class="lg:hidden flex flex-col">
    <div class="flex gap-4 items-start">
      <div class="flex flex-col items-center shrink-0 mt-1">
        <div
          class="
            w-4 h-4 rounded-full bg-hanakai-300 ring-4 ring-hanakai-100
            dark:ring-hanakai-800
          "
        ></div>

        <div class="w-0.5 flex-1 bg-neutral-200 dark:bg-neutral-700 mt-1 min-h-12"></div>
      </div>

      <div>
        <p class="font-bold text-lg mb-0.5">
          Up to $30k/year
          <span class="text-sm font-normal">(currently here – $26k)</span>
        </p>

        <p class="text-base">
          Funds one day a week of Tim’s time as lead maintainer.
        </p>
      </div>
    </div>

    <div class="flex gap-4 items-start">
      <div class="flex flex-col items-center shrink-0 mt-1">
        <div class="w-4 h-4 rounded-full bg-neutral-300 dark:bg-neutral-600"></div>
        <div class="w-0.5 flex-1 bg-neutral-200 dark:bg-neutral-700 mt-1 min-h-12"></div>
      </div>

      <div>
        <p class="font-bold text-lg mb-0.5">$30–40k/year</p>

        <p class="text-base">
          Builds a reserve for community and promotional activities.
        </p>
      </div>
    </div>

    <div class="flex gap-4 items-start">
      <div class="shrink-0 mt-1">
        <div class="w-4 h-4 rounded-full bg-neutral-300 dark:bg-neutral-600"></div>
      </div>

      <div>
        <p class="font-bold text-lg mb-0.5">Beyond $40k/year</p>

        <p class="text-base">
          Pays additional Hanakai maintainers for their ongoing work.
        </p>
      </div>
    </div>
  </div>

  <p
    class="
      text-base text-neutral-500 dark:text-neutral-400 text-center mt-10
      max-w-2xl mx-auto
    "
  >
    We use
    <a href="https://opencollective.com/hanami" class="
      underline decoration-(--hk-color-text-link-underline)
      decoration-[3px] [text-decoration-skip-ink:none]
      text-(--hk-color-text-link)
      hover:text-(--hk-color-text-link-active)
    ">Open Collective</a>,
    a platform designed for open-source projects. All income and expenses are
    publicly visible – you can see exactly where every dollar goes.
  </p>
</section>

<%# Business sponsors %>
<section class="py-12 lg:py-16 max-w-6xl mx-auto w-full">
  <header class="text-center mb-10 max-w-3xl mx-auto">
    <h2 class="text-4xl lg:text-5xl font-black tracking-tighter mb-5">
      Become a business sponsor
    </h2>

    <p class="text-2xl text-balance">
      As a Hanakai business sponsor, you’ll get private chat with maintainers,
      priority attention on issues, your logo on our website, and shoutouts in
      release announcements.
    </p>
  </header>

  <%# Pricing cards %>
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-12">
    <%# Platinum %>
    <div
      class="
        theme-hanami bg-neutral border-3 b-primary rounded-2xl shadow-lg
        overflow-hidden flex flex-col
      "
    >
      <div class="px-6 py-5">
        <h3 class="text-3xl font-black tracking-tighter text-primary">
          Platinum
        </h3>

        <p class="text-xl mt-1">$12,000/year</p>
        <%= render "svgs/wiggle", height: 14, stroke_width: 2, class_name: "text-primary mt-4" %>
      </div>

      <div class="p-6 pt-0 flex flex-col flex-1">
        <ul class="space-y-3 mb-8 flex-1">
          <% [
            "Large logo on Hanakai home page",
            "Logo in the footer of all Hanakai pages, including docs",
            "Acknowledgement in major and minor release announcements",
            "Access to private chat",
            "Priority for issues & requests",
            "Twice-yearly call with Tim",
          ].each do |benefit| %>
            <li class="flex items-start gap-2">
              <%= render "svgs/icons/check", width: 18, height: 18, class_name: "shrink-0 mt-0.5 text-primary fill-current" %>
              <span><%= benefit %></span>
            </li>
          <% end %>
        </ul>

        <%= render_with_slots "shared/components/button_primary",
              href: "https://opencollective.com/hanami",
              label: "Become a sponsor",
              class_name: "self-start" do |btn| %>
          <% btn.slot :suffix do %>
            <%= render "svgs/icons/arrow_right", width: 20, height: 18, class_name: "fill-current" %>
          <% end %>
        <% end %>
      </div>
    </div>

    <%# Gold %>
    <div
      class="
        theme-dry bg-neutral border-3 b-primary rounded-2xl shadow-lg
        overflow-hidden flex flex-col
      "
    >
      <div class="px-6 py-5">
        <h3 class="text-3xl font-black tracking-tighter text-primary">Gold</h3>

        <p class="text-xl mt-1">$6,000/year</p>
        <%= render "svgs/wiggle", height: 14, stroke_width: 2, class_name: "text-primary mt-4" %>
      </div>

      <div class="p-6 pt-0 flex flex-col flex-1">
        <ul class="space-y-3 mb-8 flex-1">
          <% [
            "Medium logo on Hanakai home page",
            "Acknowledgement in major release announcements",
            "Access to private chat",
            "Priority for issues & requests",
            "Yearly call with Tim",
          ].each do |benefit| %>
            <li class="flex items-start gap-2">
              <%= render "svgs/icons/check", width: 18, height: 18, class_name: "shrink-0 mt-0.5 text-primary fill-current" %>
              <span><%= benefit %></span>
            </li>
          <% end %>
        </ul>

        <%= render_with_slots "shared/components/button_primary",
              href: "https://opencollective.com/hanami",
              label: "Become a sponsor",
              class_name: "self-start" do |btn| %>
          <% btn.slot :suffix do %>
            <%= render "svgs/icons/arrow_right", width: 20, height: 18, class_name: "fill-current" %>
          <% end %>
        <% end %>
      </div>
    </div>

    <%# Silver %>
    <div
      class="
        theme-rom bg-neutral border-3 b-primary rounded-2xl shadow-lg
        overflow-hidden flex flex-col
      "
    >
      <div class="px-6 py-5">
        <h3 class="text-3xl font-black tracking-tighter text-primary">
          Silver
        </h3>

        <p class="text-xl mt-1">$3,000/year</p>
        <%= render "svgs/wiggle", height: 14, stroke_width: 2, class_name: "text-primary mt-4" %>
      </div>

      <div class="p-6 pt-0 flex flex-col flex-1">
        <ul class="space-y-3 mb-8 flex-1">
          <% [
            "Small logo on Hanakai home page",
            "Acknowledgement in major release announcements",
            "Access to private chat",
          ].each do |benefit| %>
            <li class="flex items-start gap-2">
              <%= render "svgs/icons/check", width: 18, height: 18, class_name: "shrink-0 mt-0.5 text-primary fill-current" %>
              <span><%= benefit %></span>
            </li>
          <% end %>
        </ul>

        <%= render_with_slots "shared/components/button_primary",
              href: "https://opencollective.com/hanami",
              label: "Become a sponsor",
              class_name: "self-start" do |btn| %>
          <% btn.slot :suffix do %>
            <%= render "svgs/icons/arrow_right", width: 20, height: 18, class_name: "fill-current" %>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>

  <p class="text-center text-xl">
    Please
    <a href="mailto:sponsor@hanakai.org" class="
      text-[var(--hk-color-text-link)]
      underline
      decoration-[var(--hk-color-text-link-underline)]
      decoration-[3px]
      [text-decoration-skip-ink:none]
      hover:text-[var(--hk-color-text-link-active)]
    ">reach out</a>
    if you want to discuss any aspect of business sponsorship.
  </p>
</section>

