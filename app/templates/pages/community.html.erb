<% content_for :title, "Community" %>

<%= content_for :pre_main do %>
  <div class="h-0 overflow-visible pt-4 lg:pt-8 pointer-events-none relative z-0">
    <%= render "svgs/hero_illustration", show_logos: false %>
  </div>
<% end %>

<%# Hero %>
<section class="py-12 lg:py-16 text-center max-w-3xl mx-auto">
  <div class="flex justify-center mb-6">
    <%= render "svgs/hanakai_logo", width: 134, height: 134 %>
  </div>

  <h1
    class="
      text-5xl lg:text-7xl font-black tracking-tighter leading-none mb-6
      text-balance
    "
  >
    Built on community
  </h1>

  <p class="text-2xl text-balance mb-6">
    Every part of this project comes from the people in these spaces
  </p>
</section>

<%# Community link blocks %>
<section class="pb-12 lg:pb-16 max-w-6xl mx-auto w-full">
  <%# Values block %>
  <div class="flex flex-col lg:flex-row gap-5 lg:gap-16 items-center mb-12">
    <div class="lg:w-7/12 flex justify-center lg:justify-end lg:order-2">
      <div class="relative w-full">
        <%# Photo slot 1: hanakai tint, top-left %>
        <div class="relative z-0 w-[65%] rounded-xl overflow-hidden shadow-lg">
          <div class="relative">
            <div
              class="absolute inset-0 z-0"
              style="background: oklch(from var(--color-hanami-400) calc(l + 0.09) calc(c + 0.1) h)"
            ></div>

            <%# First image is in flow to maintain aspect ratio %>
            <img
              src="<%= asset_url("community-1.png") %>"
              alt="Hanakai community members"
              class="
                community-slide block w-full grayscale relative z-10
                mix-blend-luminosity contrast-120
              "
            >

            <img
              src="<%= asset_url("community-3.png") %>"
              alt="Hanakai community members"
              class="
                community-slide absolute inset-0 w-full h-full object-cover
                grayscale z-10 mix-blend-luminosity contrast-120
              "
            >

            <img
              src="<%= asset_url("community-5.png") %>"
              alt="Hanakai community members"
              class="
                community-slide absolute inset-0 w-full h-full object-cover
                grayscale z-10 mix-blend-luminosity contrast-120
              "
            >
          </div>
        </div>

        <%# Photo slot 2: rom tint, bottom-right, overlapping %>
        <div
          class="
            relative z-10 w-[65%] ml-auto -mt-12 rounded-xl overflow-hidden
            shadow-lg
          "
        >
          <div class="relative">
            <div
              class="absolute inset-0 z-0"
              style="background: oklch(from var(--color-rom-400) calc(l + 0.2) calc(c + 0.2) h)"
            ></div>

            <img
              src="<%= asset_url("community-2.png") %>"
              alt="Hanakai community members"
              class="
                community-slide block w-full grayscale relative z-10
                mix-blend-luminosity contrast-120
              "
            >

            <img
              src="<%= asset_url("community-4.png") %>"
              alt="Hanakai community members"
              class="
                community-slide absolute inset-0 w-full h-full object-cover
                grayscale z-10 mix-blend-luminosity contrast-120
              "
            >

            <img
              src="<%= asset_url("community-6.png") %>"
              alt="Hanakai community members"
              class="
                community-slide absolute inset-0 w-full h-full object-cover
                grayscale z-10 mix-blend-luminosity contrast-120
              "
            >
          </div>
        </div>
      </div>
    </div>

    <div class="lg:w-5/12 pb-8 lg:ml-7">
      <p class="text-xl lg:text-2xl mb-3">
        Our community is a place where people of all backgrounds and experience
        levels can feel respected, and can share and grow. This is a space we
        want you to feel proud of, and feel safe within.
      </p>

      <p class="text-xl lg:text-2xl">
        <strong>We do not tolerate</strong> nazis, transphobes, racists, or any
        kind of bigotry.
        <a href="/conduct" class="
          text-link underline decoration-(--hk-color-text-link-underline)
          decoration-[3px] [text-decoration-skip-ink:none]
          hover:text-(--hk-color-text-link-active)
        ">See our Code of Conduct for more.</a>
      </p>
    </div>
  </div>

  <header class="text-center mb-10">
    <h2 class="text-4xl lg:text-5xl font-black tracking-tighter mb-5">
      Get involved
    </h2>

    <p class="text-2xl lg:text-3xl tracking-tight text-balance">
      Find us in these spaces
    </p>
  </header>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-5">
    <a
      href="https://discourse.hanamirb.org"
      class="
        theme-hanami group flex flex-col items-center text-center p-8 rounded-2xl
        border-3 b-primary bg-(--hk-color-surface-raised)
        shadow-sm hover:shadow-lg transition-shadow duration-200
      "
    >
      <%= render "svgs/icons/chat_text", width: 32, height: 32, class_name: "mb-4 text-primary" %>

      <span class="text-2xl tracking-tighter font-bold mb-2">
        Discussion forum
      </span>

      <span class="text-xl">
        Ask questions, share ideas, and discuss all things Hanakai.
      </span>
    </a>

    <a
      href="https://discord.com/invite/KFCxDmk3JQ"
      class="
        theme-dry group flex flex-col items-center text-center p-8 rounded-2xl
        border-3 b-primary bg-(--hk-color-surface-raised)
        shadow-sm hover:shadow-lg transition-shadow duration-200
      "
    >
      <%= render "svgs/icons/discord_logo", width: 32, height: 32, class_name: "mb-4 fill-current text-primary" %>

      <span class="text-2xl tracking-tighter font-bold mb-2">Discord</span>

      <span class="text-xl">
        Join the conversation and get help in real time.
      </span>
    </a>

    <a
      href="https://github.com/hanami"
      class="
        theme-rom group flex flex-col items-center text-center p-8 rounded-2xl
        border-3 b-primary bg-(--hk-color-surface-raised)
        shadow-sm hover:shadow-lg transition-shadow duration-200
      "
    >
      <%= render "svgs/icons/github_logo", width: 32, height: 32, class_name: "mb-4 text-primary" %>

      <span class="text-2xl tracking-tighter font-bold mb-2">GitHub</span>

      <span class="text-xl">
        Browse the source, file issues, and contribute changes.
      </span>
    </a>
  </div>
</section>

<%# Team %>
<section class="py-12 lg:py-16 max-w-6xl mx-auto w-full">
  <header class="text-center mb-12">
    <h2 class="text-4xl lg:text-5xl font-black tracking-tighter mb-5">
      Our team
    </h2>

    <p class="text-2xl lg:text-3xl tracking-tight text-balance">
      Hanakai happens thanks to the work of our maintainers. Thank you to these
      amazing people!
    </p>
  </header>

  <div
    class="
      grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5
      xl:grid-cols-6 gap-4
    "
    data-testid="team-roster"
  >
    <% team_members.each do |member| %>
      <div class="team-member flex flex-col items-center text-center mb-4">
        <a href="https://github.com/<%= member.github_user %>">
          <img
            alt="<%= member.name %>"
            class="
              avatar w-20 h-20 rounded-full mb-2 transition duration-200
              hover:scale-105 hover:-rotate-2 hover:shadow-md
            "
            height="80"
            src="https://avatars.githubusercontent.com/<%= member.github_user %>?size=128"
            width="80"
          >
        </a>

        <% if member.team == "core" %>
          <span
            class="
              core-pill text-xs font-bold px-1.5 py-0.5 rounded-full
              bg-hanakai-100 text-hanakai-700
              dark:bg-hanakai-900 dark:text-hanakai-300 absolute -mt-3
            "
          >
            Core
          </span>
        <% end %>

        <div class="flex items-center gap-1.5 mb-1">
          <span class="font-semibold text-lg leading-tight">
            <%= member.name %>
          </span>
        </div>

        <a
          href="https://github.com/<%= member.github_user %>"
          target="_blank"
          rel="noopener"
          class="
            text-sm text-neutral-500 dark:text-neutral-400
            hover:text-neutral-900 dark:hover:text-neutral-100
            font-mono
          "
        >
          @<%= member.github_user %>
        </a>

        <span class="text-sm text-neutral-500 dark:text-neutral-400">
          <%= member.location %>

          <% if member.active_since %>
            <span class="inline-block px-[3px]">·</span>
            Since
            <%= member.active_since %>
          <% end %>
        </span>
      </div>
    <% end %>
  </div>

  <p class="mt-10 text-xl text-center max-w-3xl mx-auto">
    <strong>Want to get involved?</strong> Our team looks for your track record
    in the community. Be active in our community spaces, work on documentation,
    file and fix issues, and be proactive in helping others and sharing your
    Hanakai experiences.
  </p>
</section>
