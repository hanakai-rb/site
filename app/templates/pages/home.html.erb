<%# Hero %>
<%= content_for :pre_main do %>
  <div class="pt-4 lg:pt-8"><%= render "svgs/hero_illustration" %></div>
<% end %>

<section class="py-8 text-center">
  <h1
    class="
      text-4xl lg:text-6xl font-black tracking-tighter leading-none max-w-4xl
      mx-auto text-balance mb-6
    "
  >
    Let your Ruby bloom
  </h1>

  <p class="text-2xl text-balance mb-3 max-w-4xl mx-auto">
    Hanakai is a family of Ruby tools that help you write clearer, more
    maintainable apps.
  </p>
</section>

<%# Projects %>
<section class="py-4">
  <div class="grid grid-cols-1 lg:grid-cols-3 lg:grid-rows-[repeat(6,auto)] gap-x-6 gap-y-6">
    <%# Hanami %>
    <%= render_with_slots "pages/home/project_card",
          theme: "theme-hanami",
          name: render("shared/names/hanami"),
          description: <<~DESC,
            A complete framework for building apps with structure and clarity.
          DESC
          primary_href: "/projects/hanami",
          primary_label: "Get building with Hanami",
          docs_href: "/learn/hanami" do |card| %>
      <%= card.slot :logo do %>
        <%= render "svgs/hanami_logo", width: 56, height: 54 %>
      <% end %>

      <%= card.slot :features do %>
        <li>
          <h3 class="font-bold mb-0.5">Batteries included</h3>

          <p class="leading-snug">
            Everything you need to build a production-ready Ruby app: routes,
            actions, views and persistence, and dedicated tools for your
            business logic.
          </p>
        </li>

        <li>
          <h3 class="font-bold mb-0.5">Apps that grow with you</h3>

          <p class="leading-snug">
            Clear layers and a modular slice architecture mean you can start
            simple and gracefully evolve your app as it grows.
          </p>
        </li>

        <li>
          <h3 class="font-bold mb-0.5">Built for speed</h3>

          <p class="leading-snug">
            Lean gems and smart code loading keep your app fast and local dev
            snappy, every step of the way.
          </p>
        </li>
      <% end %>
    <% end %>

    <%# Dry %>
    <%= render_with_slots "pages/home/project_card",
          theme: "theme-dry",
          name: render("shared/names/dry"),
          description: <<~DESC,
            Validation, types, functional patterns and more, for robust code in any Ruby app.
          DESC
          primary_href: "/projects/dry",
          primary_label: "Dive into Dry",
          docs_href: "/learn/dry" do |card| %>
      <%= card.slot :logo do %>
        <%= render "svgs/dry_logo", width: 56, height: 56 %>
      <% end %>

      <%= card.slot :features do %>
        <li>
          <h3 class="font-bold mb-0.5">A comprehensive toolkit</h3>

          <p class="leading-snug">
            A broad collection of libraries covering validation, types, monads,
            events, and more — each solving one problem and solving it well.
          </p>
        </li>

        <li>
          <h3 class="font-bold mb-0.5">Works everywhere</h3>

          <p class="leading-snug">
            Dry gems make no framework assumptions. Use them in Hanami, Rails,
            or standalone, and combine them however you like.
          </p>
        </li>

        <li>
          <h3 class="font-bold mb-0.5">Proven in production</h3>

          <p class="leading-snug">
            Built on over a decade of refinement and real-world use, these are
            proven tools you can depend on for the long term.
          </p>
        </li>
      <% end %>
    <% end %>

    <%# Rom %>
    <%= render_with_slots "pages/home/project_card",
          theme: "theme-rom",
          name: render("shared/names/rom"),
          description: <<~DESC,
            A powerful, flexible persistence toolkit that keeps your domain logic clean.
          DESC
          primary_href: "/projects/rom",
          primary_label: "Tame your data with Rom",
          docs_href: "/learn/rom" do |card| %>
      <%= card.slot :logo do %>
        <%= render "svgs/rom_logo", width: 52, height: 56 %>
      <% end %>

      <%= card.slot :features do %>
        <li>
          <h3 class="font-bold mb-0.5">Control your data</h3>

          <p class="leading-snug">
            Write exactly the queries you need and keep your domain logic free
            from persistence concerns.
          </p>
        </li>

        <li>
          <h3 class="font-bold mb-0.5">Plain, predictable data</h3>

          <p class="leading-snug">
            Results are plain data objects with no mutable state and no way to
            trigger unexpected queries. Safe to pass around and easy to test.
          </p>
        </li>

        <li>
          <h3 class="font-bold mb-0.5">Fast by design</h3>

          <p class="leading-snug">
            Rom’s data mapping approach means less overhead and better
            performance than traditional ORMs.
          </p>
        </li>
      <% end %>
    <% end %>
  </div>
</section>

<%= render "shared/community" %>

<%= content_for :post_main do %>
  <%= render "shared/sponsors" %>
<% end %>
