<div class="<%= theme %> flex flex-col border-3 b-primary rounded-2xl p-6 shadow-lg">
  <div class="flex items-center gap-4 mb-5">
    <%= render_slot :logo %>
    <h2 class="text-4xl font-black tracking-tight text-primary"><%= name %></h2>
  </div>

  <p class="text-lg leading-snug mb-6"><%= description %></p>

  <div class="mb-6">
    <%= render_with_slots "shared/components/button_primary", href: primary_href, label: primary_label do |btn| %>
      <% btn.slot :suffix do %>
        <%= render "svgs/icons/arrow_right", width: 20, height: 18, class_name: "fill-current" %>
      <% end %>
    <% end %>
  </div>

  <%= render "svgs/wiggle", height: 14, stroke_width: 2, class_name: "text-primary mb-6" %>

  <ul class="flex flex-col gap-5 flex-1">
    <%= render_slot :features %>
  </ul>

  <div class="mt-6">
    <%= render_with_slots "shared/components/button_secondary", href: docs_href, label: "View docs" do |btn| %>
      <% btn.slot :suffix do %>
        <%= render "svgs/icons/book_open_text", width: 24, height: 24, class_name: "text-current" %>
      <% end %>
    <% end %>
  </div>
</div>
