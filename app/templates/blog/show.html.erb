<% content_for :title, post.title %>

<article class="lg:pt-12 pt-5 theme-<%= org %>">
  <header class="lg:max-w-200 mx-auto mb-6 text-center">
    <time
      class="
        block font-mono uppercase text-xs font-semibold text-primary
        tracking-wide mb-3
      "
      data-testid="date"
      datetime="<%= post.published_datetime %>"
    >
      <%= post.published_date %>
    </time>

    <h1
      class="
        lg:text-[2.625rem] text-4xl font-extrabold mb-4 tracking-tight
        leading-tight text-balance
      "
    >
      <%= post.title %>
    </h1>

    <% if post.respond_to?(:author) && post.author && !post.author.to_s.strip.empty? %>
      <p
        class="
          text-lg text-neutral-500 dark:text-neutral-400 flex items-center
          justify-center gap-2
        "
        data-testid="author"
      >
        <% if author_team_member %>
          <%= image_tag "https://avatars.githubusercontent.com/#{author_team_member.github_user}?size=80",
              alt: "Avatar for #{post.author}",
              class: "avatar w-10 h-10 rounded-full border-2 border-neutral-200 dark:border-neutral-700",
              height: 40,
              width: 40 %>
        <% end %>

        <span><%= post.author %></span>
      </p>
    <% end %>
  </header>

  <div class="lg:max-w-[80%] mx-auto flex gap-2 items-center">
    <%= render "svgs/wiggle", class_name: "text-[var(--hk-color-b-primary)] flex-1", height: 14, stroke_width: 2 %>
    <%= render "svgs/#{org || "hanakai"}_logo", width: 30, height: 30 %>
    <%= render "svgs/wiggle", class_name: "text-[var(--hk-color-b-primary)] flex-1", height: 14, stroke_width: 2 %>
  </div>

  <% if post.show_toc? && post.nested_headings.length > 0 %>
    <div class="lg:hidden -mx-4 mb-4">
      <details>
        <summary
          class="
            lg:px-6 lg:py-4 px-4 pt-1 pb-3 cursor-pointer font-mono text-xs font-semibold
            text-primary tracking-wider uppercase flex items-center
            justify-between
          "
        >
          <span>On this page</span>

          <svg
            class="w-4 h-4 transition-transform [details[open]_&]:rotate-180"
            fill="currentColor"
            viewBox="0 0 20 20"
          >
            <path
              fill-rule="evenodd"
              d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"
              clip-rule="evenodd"
            />
          </svg>
        </summary>

        <nav
          class="px-6 pb-4"
          data-defo-target-current="<%= { activeClassNames: ["font-bold", "b-primary"] }.to_json %>"
        >
          <%= render "doc_pages/toc_headings", headings: post.nested_headings, testid: nil, depth: 0 %>
        </nav>
      </details>
    </div>
  <% end %>

  <div class="lg:max-w-[80%] mx-auto">
    <div class="lg:grid lg:grid-cols-13 lg:gap-8">
      <div class="lg:col-span-10 lg:pt-7">
        <div class="content content--large"><%= post.content_html %></div>
      </div>

      <% if post.show_toc? && post.nested_headings.length > 0 %>
        <aside
          class="
            lg:col-span-3 lg:self-start
            lg:pt-8 lg:sticky lg:top-[calc(var(--hk-nav-height))]
            lg:max-h-[calc(100vh-var(--hk-nav-height)-(var(--spacing)*8))]
            relative
            flex flex-col
          "
        >
          <%= render "doc_pages/toc_desktop", org: org || "hanakai", headings: post.nested_headings %>
        </aside>
      <% end %>
    </div>
  </div>
</article>
