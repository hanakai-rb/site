<% base_class = defined?(class_name) ? class_name : ""
  show_animated = defined?(animated) ? animated : true %>

<% if show_animated %>
  <%= render "svgs/dry_logo_static", width: width, height: height, class_name: "motion-safe:hidden #{base_class}".strip %>
  <%= render "svgs/dry_logo_animated", width: width, height: height, class_name: "motion-reduce:hidden #{base_class}".strip %>
<% else %>
  <%= render "svgs/dry_logo_static", width: width, height: height, class_name: base_class %>
<% end %>
