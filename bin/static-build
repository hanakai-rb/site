#!/usr/bin/env sh

set -eu

export SITE_STATIC_BUILD=true
export HANAMI_ENV=production

# Clean previous build to avoid caching issues
rm -rf build public/pagefind public/og

# Compile frontend assets
bundle exec hanami assets compile

# Generate og:images (writes into public/og/, copied into build/ below)
bundle exec rake og:generate

# Generate sitemap.
bundle exec rake sitemap:create

# Build with Parklife - and forward arguments sent to this script.
# Note: Search index is built as part of the Parklife build process (see Parkfile)
bundle exec parklife build "$@"

# Copy static content files to build/
bundle exec rake content:copy_files

# Copy all public resources to build/
if [ -d public ]; then
  cp -R public/* build
fi

# Mirror the search index back into public/ so spec helpers (and future runs
# of this script) find it without rebuilding.
if [ -d build/pagefind ]; then
  rm -rf public/pagefind
  cp -R build/pagefind public/pagefind
fi

# List all files in the build (useful for debugging).
echo
find build -type f | sort

bin/generate-redirects
